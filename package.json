{
  "name": "@anupheaus/react-ui",
  "version": "0.0.70",
  "main": "./dist/index.js",
  "repository": "https://github.com/Anupheaus/react-ui.git",
  "author": "Anupheaus",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  },
  "private": false,
  "scripts": {
    "start": "storybook dev -p 6006",
    "build": "webpack --mode production",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.prod.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "findDeclarationErrors": "tsc --declaration --declarationDir ./dist --emitDeclarationOnly",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test-storybook:coverage": "test-storybook --coverage",
    "test-storybook:play": "test-storybook --includeTags=play-fn",
    "test-storybook:ci": "pnpm exec playwright install chromium && pnpm run build-storybook --quiet && npx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6006 --silent\" \"npx wait-on tcp:127.0.0.1:6006 && pnpm run test-storybook -- --ci\"",
    "test-storybook:update-snapshots": "pnpm run build-storybook --quiet && npx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6006 --silent\" \"npx wait-on tcp:127.0.0.1:6006 && pnpm run test-storybook -- -u\"",
    "test-storybook:ci:play": "pnpm exec playwright install chromium && pnpm run build-storybook --quiet && npx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6006 --silent\" \"npx wait-on tcp:127.0.0.1:6006 && pnpm run test-storybook -- --ci --includeTags=play-fn\"",
    "test-storybook:docker": "node scripts/test-storybook-docker.mjs",
    "test-storybook:docker:update": "node scripts/test-storybook-docker.mjs --update-snapshots"
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "typings": "dist/index",
  "dependencies": {
    "@anupheaus/common": "^0.1.29",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/material": "^5.18.0",
    "@mui/x-data-grid-premium": "^7.28.1",
    "@mui/x-date-pickers": "^7.2.0",
    "@uiw/react-md-editor": "^4.1.0",
    "color": "^4.2.3",
    "crypto-js": "^4.2.0",
    "csstype": "^3.1.3",
    "flatted": "^3.2.9",
    "luxon": "^3.4.4",
    "qr-code-styling": "^1.9.2",
    "react-async-script": "^1.2.0",
    "react-google-recaptcha-enterprise": "^1.0.3",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "react-markdown": "^10.1.0",
    "signature_pad": "^5.1.3",
    "tss-react": "^4.9.3",
    "use-resize-observer": "^9.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@faker-js/faker": "^8.3.1",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-onboarding": "10.2.10",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/builder-webpack5": "10.2.10",
    "@storybook/react": "^10.2.10",
    "@storybook/react-webpack5": "10.2.10",
    "@storybook/test-runner": "^0.24.2",
    "@swc/core": "^1.3.99",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@types/color": "^3.0.6",
    "@types/crypto-js": "^4.2.1",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-async-script": "^1.2.5",
    "@types/react-dom": "^18.2.18",
    "@types/react-google-recaptcha-enterprise": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "babel-loader": "^10.1.1",
    "babel-plugin-istanbul": "^8.0.0",
    "circular-dependency-plugin": "^5.2.2",
    "concurrently": "^9.1.0",
    "css-loader": "^6.8.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-storybook": "10.2.10",
    "http-server": "^14.1.1",
    "playwright": "^1.49.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "10.2.10",
    "terser-webpack-plugin": "^5.3.9",
    "ts-loader": "^9.5.1",
    "ts-toolbelt": "^9.6.0",
    "typescript": "^5.6.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "pnpm": {
    "overrides": {}
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}

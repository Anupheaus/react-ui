{
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "experimentalDecorators": true,
    "removeComments": true,
    "noEmit": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "lib": [
      "DOM",
      "ES2022"
    ],
    "target": "ES2022",
    "sourceMap": true,
    "jsx": "react-jsx",
    "paths": {
      "@anupheaus/common": ["../common/src"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}